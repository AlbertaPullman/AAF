generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  MASTER
  ADMIN
  PLAYER
}

enum WorldVisibility {
  PUBLIC
  PASSWORD
  FRIENDS
  PRIVATE
}

enum WorldRole {
  GM
  PLAYER
  OBSERVER
  ASSISTANT
}

enum WorldMemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum CharacterType {
  PC
  NPC
}

enum MessageType {
  GLOBAL
  WORLD
  PRIVATE
  SYSTEM
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum StoryEventScope {
  ALL
  PLAYER
}

enum StoryEventStatus {
  DRAFT
  OPEN
  RESOLVED
  CLOSED
}

enum FolderType {
  SCENE
  CHARACTER
  ABILITY
  ITEM
  PROFESSION
  RACE
  BACKGROUND
  FATE_CLOCK
  DECK
  RANDOM_TABLE
}

model User {
  id                String        @id @default(cuid())
  username          String        @unique
  passwordHash      String
  displayName       String?
  avatarUrl         String?
  platformRole      PlatformRole  @default(PLAYER)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  ownedWorlds       World[]       @relation("WorldOwner")
  worldMemberships  WorldMember[]
  characters        Character[]
  sentMessages      Message[]     @relation("MessageSender")
  privateMessages   Message[]     @relation("MessageRecipient")
  aiSessions        AiSession[]
  storyEventsCreated StoryEvent[] @relation("StoryEventCreator")
  friendRequestsSent     Friend[] @relation("FriendRequester")
  friendRequestsReceived Friend[] @relation("FriendAddressee")
}

model World {
  id              String          @id @default(cuid())
  name            String
  description     String?
  ownerId         String
  visibility      WorldVisibility @default(PUBLIC)
  passwordHash    String?
  inviteCode      String?         @unique
  inviteExpiresAt DateTime?
  /// GM 设置的世界级视觉风格包 id（如 "dark-arcane"）。null 表示跟随系统默认 + 玩家偏好。
  themePack            String?
  /// true = 锁定本世界风格，覆盖所有玩家个人偏好；仅在 themePack 非空时生效。
  themePackForcedByGM  Boolean   @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  owner           User            @relation("WorldOwner", fields: [ownerId], references: [id])
  members         WorldMember[]
  scenes          Scene[]
  characters      Character[]
  messages        Message[]
  aiSessions      AiSession[]
  storyEvents     StoryEvent[]
  abilities       AbilityDefinition[]
  races           RaceDefinition[]
  professions     ProfessionDefinition[]
  backgrounds     BackgroundDefinition[]
  items           ItemDefinition[]
  fateClocks      FateClock[]
  decks           DeckDefinition[]
  randomTables    RandomTable[]
  folders         Folder[]

  @@index([ownerId])
  @@index([visibility])
}

// ──────────── 文件夹 (CP-01) ──────────────────────
// 跨资源类型的多级分类容器。资源 (Scene / Character / Ability / Item /
// Profession / Race / Background / FateClock / Deck / RandomTable) 通过
// `folderId` 引用本表。每个 (worldId, type) 子树独立。`folderPath` 字段在
// 兼容期保留，后续 3 个版本删除。

model Folder {
  id          String      @id @default(cuid())
  worldId     String
  parentId    String?
  type        FolderType
  name        String
  color       String?
  icon        String?
  sortOrder   Int         @default(0)
  collapsed   Boolean     @default(false)
  permissionMode String    @default("DEFAULT")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  world       World       @relation(fields: [worldId], references: [id])
  parent      Folder?     @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[]    @relation("FolderTree")

  scenes              Scene[]
  characters          Character[]
  abilities           AbilityDefinition[]
  items               ItemDefinition[]
  professions         ProfessionDefinition[]
  races               RaceDefinition[]
  backgrounds         BackgroundDefinition[]
  fateClocks          FateClock[]
  decks               DeckDefinition[]
  randomTables        RandomTable[]

  @@index([worldId, type])
  @@index([parentId])
}

model WorldMember {
  id        String            @id @default(cuid())
  worldId   String
  userId    String
  displayName String?
  role      WorldRole         @default(PLAYER)
  status    WorldMemberStatus @default(ACTIVE)
  joinedAt  DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  world     World             @relation(fields: [worldId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@unique([worldId, userId])
  @@index([userId])
}

model Scene {
  id                 String   @id @default(cuid())
  worldId            String
  folderId           String?
  name               String
  backgroundImageUrl String?
  gridSize           Int?
  sortOrder          Int      @default(0)
  canvasState        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  world              World    @relation(fields: [worldId], references: [id])
  folder             Folder?  @relation(fields: [folderId], references: [id])

  @@unique([worldId, sortOrder])
  @@index([worldId, folderId])
}

model Character {
  id          String        @id @default(cuid())
  worldId     String
  folderId    String?
  userId      String?
  name        String
  avatarUrl   String?
  type        CharacterType @default(PC)
  sortOrder   Int           @default(0)
  permissionMode String     @default("DEFAULT")
  stats       Json?
  snapshot    Json?
  aiConfig    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  world       World         @relation(fields: [worldId], references: [id])
  folder      Folder?       @relation(fields: [folderId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])
  aiSessions  AiSession[]

  @@index([worldId])
  @@index([userId])
  @@index([worldId, folderId])
}

model Message {
  id         String      @id @default(cuid())
  type       MessageType
  worldId    String?
  channelKey String?
  fromUserId String
  toUserId   String?
  content    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  world      World?      @relation(fields: [worldId], references: [id])
  fromUser   User        @relation("MessageSender", fields: [fromUserId], references: [id])
  toUser     User?       @relation("MessageRecipient", fields: [toUserId], references: [id])

  @@index([type, createdAt])
  @@index([worldId, createdAt])
  @@index([fromUserId])
  @@index([toUserId])
}

model Friend {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id])
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model AiSession {
  id        String   @id @default(cuid())
  worldId   String
  npcId     String
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  world     World    @relation(fields: [worldId], references: [id])
  npc       Character @relation(fields: [npcId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([worldId])
  @@index([npcId])
  @@index([userId])
}

model StoryEvent {
  id              String          @id @default(cuid())
  worldId         String
  title           String
  description     String          @default("")
  scope           StoryEventScope @default(ALL)
  targetUserId    String?
  sceneId         String?
  status          StoryEventStatus @default(OPEN)
  options         Json
  narrativeRequests Json?
  summary         String?
  finalOutcome    String?
  processTimeline Json?
  createdBy       String
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  world           World           @relation(fields: [worldId], references: [id])
  creator         User            @relation("StoryEventCreator", fields: [createdBy], references: [id])

  @@index([worldId, createdAt])
  @@index([worldId, status])
  @@index([targetUserId])
}

// ──────────── 能力系统 ──────────────────────

model AbilityDefinition {
  id            String   @id @default(cuid())
  worldId       String
  name          String
  folderPath    String   @default("")
  category      String   // spell | combatTechnique | feature | racial | item | custom
  source        String   // race | profession | talent | equipment | item | background | feat | custom
  sourceName    String   @default("")
  activation    String   @default("active")
  actionType    String   @default("standard")
  description   String   @default("")
  rulesText     String   @default("")
  iconUrl       String?
  tags          Json     @default("[]")
  levelReq      Int?
  range         String?  // 数字(尺) | "self" | "touch" | "special"
  aoeShape      String?  // none | sphere | cube | cone | line | cylinder
  aoeSize       Int?
  resourceCosts Json     @default("[]")
  cooldown      Json?
  duration      String   @default("instantaneous")
  durationValue Int?
  concentration Boolean  @default(false)
  checkType     String?  // attack | savingThrow | none | contest
  attackAttr    String?  // strength | dexterity | ...
  saveDC        Json?
  damageRolls   Json?
  trigger       Json?
  effects       Json     @default("[]")
  automation    Json?
  reactionStrat String?  // always-ask | smart-ask | auto
  spellLevel    Int?
  spellSchool   String?
  spellComps    Json?
  canUpcast     Boolean  @default(false)
  upcastEffect  String?
  sortOrder     Int      @default(0)
  folderId      String?
  permissionMode String   @default("DEFAULT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  world         World    @relation(fields: [worldId], references: [id])
  folder        Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId, category])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
  @@index([worldId, source])
}

// ──────────── 种族定义 ──────────────────────

model RaceDefinition {
  id            String   @id @default(cuid())
  worldId       String
  name          String
  folderPath    String   @default("")
  description   String   @default("")
  loreText      String   @default("")
  iconUrl       String?
  attrBonus     Json     @default("[]")
  size          String   @default("medium")
  speed         Int      @default(30)
  darkvision    Int      @default(0)
  creatureType  String   @default("humanoid")
  languages     Json     @default("[]")
  ageDesc       String   @default("")
  traits        Json     @default("[]")
  subtypes      Json     @default("[]")
  sortOrder     Int      @default(0)
  folderId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  world         World    @relation(fields: [worldId], references: [id])
  folder        Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 职业定义 ──────────────────────

model ProfessionDefinition {
  id                  String   @id @default(cuid())
  worldId             String
  name                String
  folderPath          String   @default("")
  description         String   @default("")
  loreText            String   @default("")
  iconUrl             String?
  type                String   @default("combat")
  hitDie              String   @default("1d10")
  primaryAttribute    String   @default("strength")
  saveProficiencies   Json     @default("[]")
  armorProficiencies  Json     @default("[]")
  weaponProficiencies Json     @default("[]")
  toolProficiencies   Json     @default("[]")
  skillChoices        Json     @default("[]")
  startingEquipment   Json     @default("[]")
  startingWealth      String?
  spellcastingAttr    String?
  furyPerLevel        Float    @default(0)
  levelFeatures       Json     @default("[]")
  talentTreeIds       Json     @default("[]")
  sortOrder           Int      @default(0)
  folderId            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  world               World    @relation(fields: [worldId], references: [id])
  folder              Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 背景定义 ──────────────────────

model BackgroundDefinition {
  id               String   @id @default(cuid())
  worldId          String
  name             String
  folderPath       String   @default("")
  description      String   @default("")
  loreText         String   @default("")
  iconUrl          String?
  skillPoints      Int      @default(0)
  bonusLanguages   Int      @default(0)
  toolProficiencies Json    @default("[]")
  startingEquipment Json    @default("[]")
  features         Json     @default("[]")
  sortOrder        Int      @default(0)
  folderId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  world            World    @relation(fields: [worldId], references: [id])
  folder           Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 物品定义 ──────────────────────

model ItemDefinition {
  id            String   @id @default(cuid())
  worldId       String
  name          String
  folderPath    String   @default("")
  description   String   @default("")
  category      String   @default("gear")
  subcategory   String?
  rarity        String   @default("common")
  iconUrl       String?
  weight        Float    @default(0)
  price         Float    @default(0)
  stackable     Boolean  @default(false)
  maxStack      Int?
  requiresIdent Boolean  @default(false)
  requiresAttune Boolean @default(false)
  attuneReq     String?
  weaponProps   Json?
  armorProps    Json?
  enchantments  Json?
  enhanceSlots  Int      @default(0)
  gemSlots      Int      @default(0)
  tags          Json     @default("[]")
  sortOrder     Int      @default(0)
  folderId      String?
  permissionMode String   @default("DEFAULT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  world         World    @relation(fields: [worldId], references: [id])
  folder        Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId, category])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 命刻 ──────────────────────

model FateClock {
  id              String   @id @default(cuid())
  worldId         String
  name            String
  folderPath      String   @default("")
  description     String   @default("")
  segments        Int      @default(6)
  filledSegments  Int      @default(0)
  visibleToPlayers Boolean @default(true)
  direction       String   @default("advance")
  successThreshold Int?
  failureThreshold Int?
  status          String   @default("active")
  sceneId         String?
  history         Json     @default("[]")
  sortOrder       Int      @default(0)
  folderId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  world           World    @relation(fields: [worldId], references: [id])
  folder          Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 牌堆 ──────────────────────

model DeckDefinition {
  id            String   @id @default(cuid())
  worldId       String
  name          String
  folderPath    String   @default("")
  description   String   @default("")
  cards         Json     @default("[]")
  replacement   Boolean  @default(true)
  drawnHistory  Json     @default("[]")
  sortOrder     Int      @default(0)
  folderId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  world         World    @relation(fields: [worldId], references: [id])
  folder        Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 随机表 ──────────────────────

model RandomTable {
  id           String   @id @default(cuid())
  worldId      String
  name         String
  folderPath   String   @default("")
  description  String   @default("")
  diceFormula  String   @default("1d100")
  entries      Json     @default("[]")
  sortOrder    Int      @default(0)
  folderId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id])
  folder       Folder?  @relation(fields: [folderId], references: [id])

  @@index([worldId])
  @@index([worldId, folderPath])
  @@index([worldId, folderId])
}

// ──────────── 世界天赋树实例 ──────────────────────

model WorldTalentTreeInstance {
  id              String   @id @default(cuid())
  worldId         String
  templateId      String
  templateVersion Int
  name            String
  treeType        String   @default("PROFESSION") // PROFESSION | GENERAL
  category        String   @default("")
  graphSnapshot   Json     // 模板快照（不可变）
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  allocations     CharacterTalentAllocation[]

  @@index([worldId])
  @@unique([worldId, templateId])
}

// ──────────── 角色天赋分配 ──────────────────────

model CharacterTalentAllocation {
  id           String   @id @default(cuid())
  characterId  String
  instanceId   String
  ranks        Json     // Record<nodeId, rank> — application default: {}
  pointsSpent  Int      @default(0)
  resetCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  instance     WorldTalentTreeInstance @relation(fields: [instanceId], references: [id])

  @@unique([characterId, instanceId])
  @@index([characterId])
}
